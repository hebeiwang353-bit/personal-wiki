# ════════════════════════════════════════════════════════════════
# MemoryOS 配置文件 · 复制为 .env 并填入你的真实值
# ════════════════════════════════════════════════════════════════

# ── 选项 1：使用预设厂商（推荐，最简单） ────────────────────────
#
# 只需选一个 provider，填入对应的 API Key，立即可用。
#
# 可选值（任选其一）：
#   openai        OpenAI 官方
#   anthropic     Anthropic Claude
#   deepseek      DeepSeek 深度求索
#   dashscope     阿里通义千问
#   zhipu         智谱 GLM
#   moonshot      Kimi (Moonshot)
#   doubao        字节豆包
#   ernie         百度文心一言
#   gemini        Google Gemini（OpenAI 兼容模式）
#   grok          xAI Grok
#   mistral       Mistral AI
#   groq          Groq
#   minimax       MiniMax
#   stepfun       阶跃星辰
#   ollama        本地 Ollama（无需 API Key，填任意值）
#   lmstudio      本地 LM Studio（无需 API Key）

AI_PROVIDER=deepseek
AI_API_KEY=sk-xxxxxxxxxxxxxxxx

# 想换默认模型？取消下行注释并填写
# AI_MODEL=deepseek-chat


# ── 选项 2：自定义 OpenAI 兼容服务（高级） ──────────────────────
#
# 如果你的 AI 服务不在上面预设里，但兼容 OpenAI API 协议，
# 可以用 custom 模式手动指定 base_url 和 model：
#
# AI_PROVIDER=custom
# AI_API_KEY=sk-xxx
# AI_BASE_URL=https://your-service.com/v1
# AI_MODEL=your-model-name


# ── Azure OpenAI 用户 ─────────────────────────────────────────
#
# AI_PROVIDER=azure-openai
# AI_API_KEY=your-azure-key
# AI_BASE_URL=https://YOUR-RESOURCE.openai.azure.com/openai/deployments/YOUR-DEPLOYMENT
# AI_MODEL=gpt-4o-mini
